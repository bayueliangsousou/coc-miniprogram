/* pages/skills/skills.wxss */

/* 覆写全局 page-container：skills 页需要固定高度才能让 scroll-view 内部 sticky 生效 */
.page-container {
  height: 100vh !important;
  min-height: unset !important;
  overflow: hidden;
  box-sizing: border-box;
}

/* 社会信用评级 */
.credit-rating-section {
  background: #f8f7f3;
  border-radius: var(--radius-md);
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid var(--color-border);
  box-sizing: border-box;
}

.credit-rating-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0;
}

.credit-rating-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
}

.credit-rating-range {
  font-size: 24rpx;
  color: var(--color-primary-dark);
  background: rgba(201, 168, 76, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.credit-rating-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.credit-rating-input {
  width: 120rpx;
  height: 56rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  background: #fff;
}

.credit-rating-hint {
  font-size: 24rpx;
  color: var(--color-text-sub);
}

/* 技能点数面板 - 左右并排，吸顶 */
.points-panel {
  background: linear-gradient(135deg, #1a1a2e 0%, #2d2d4a 100%);
  border-radius: var(--radius-md);
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(26, 26, 46, 0.2);
  display: flex;
  gap: 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.points-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.points-numbers {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 2rpx;
}

.points-title {
  font-size: 24rpx;
  font-weight: bold;
  color: rgba(255,255,255,0.9);
}

.points-formula {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 2rpx;
}

.points-remain {
  font-size: 42rpx;
  font-weight: bold;
  color: #c9a84c;
  line-height: 1;
}

.points-remain.points-negative {
  color: #e74c3c;
}

.points-slash {
  font-size: 28rpx;
  color: rgba(255,255,255,0.4);
  line-height: 1;
}

.points-total {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
  line-height: 1;
}

.points-bar-wrap {
  height: 6rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 3rpx;
  overflow: hidden;
}

.points-bar-fill {
  height: 100%;
  transition: width 0.3s ease;
}

.points-bar-fill.occ-fill {
  background: linear-gradient(90deg, #c9a84c, #8b5e1a);
}

.points-bar-fill.int-fill {
  background: linear-gradient(90deg, #3498db, #2980b9);
}

.points-used-row {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
}

/* 职业和兴趣区域的特殊样式 */
.points-section.occ-section {
  padding-right: 20rpx;
}

.points-section.int-section {
  padding-left: 20rpx;
  border-left: 1rpx solid rgba(255,255,255,0.1);
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid var(--color-border);
  height: 72rpx;
}

.search-icon { font-size: 28rpx; margin-right: 12rpx; }

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-nav {
  min-width: 80rpx;
  height: 48rpx;
  background: var(--color-primary);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  margin-left: 12rpx;
}

.search-nav-empty {
  background: #e0e0e0;
}

.search-count {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  white-space: nowrap;
}

.search-nav-empty .search-count {
  color: #999;
}

/* 当前定位技能高亮 */
.skill-row.skill-highlight {
  background: rgba(201, 168, 76, 0.18);
  border-left: 4rpx solid var(--color-primary);
}

.occ-hint {
  font-size: 24rpx;
  color: var(--color-primary-dark);
  padding: 8rpx 12rpx;
  background: rgba(201,168,76,0.08);
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

/* 分类标题 */
.cat-header {
  display: flex;
  align-items: center;
  padding: 16rpx 12rpx;
  background: #1a1a2e;
  border-radius: var(--radius-sm);
  margin-bottom: 4rpx;
  margin-top: 12rpx;
}

.cat-name {
  flex: 1;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.cat-count {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
  margin-right: 8rpx;
}

.cat-arrow {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

/* 技能行 */
.skill-row {
  display: flex;
  align-items: center;
  padding: 14rpx 12rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--color-border);
}

.skill-row.is-occ {
  background: rgba(201, 168, 76, 0.05);
}

.skill-name-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.occ-dot {
  color: var(--color-primary);
  font-size: 20rpx;
}

.skill-name {
  font-size: 28rpx;
  color: var(--color-text);
}

.skill-base {
  font-size: 20rpx;
  color: #bbb;
  margin-left: 4rpx;
}

.skill-inputs {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.skill-input {
  width: 80rpx;
  height: 56rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  padding: 0;
  background: #fafafa;
}

.skill-input.input-occ {
  border-color: var(--color-primary);
  color: var(--color-primary-dark);
  background: rgba(201,168,76,0.06);
}

.skill-input.input-int {
  border-color: #3498db;
  color: #2980b9;
  background: rgba(52, 152, 219, 0.06);
}

.skill-input.input-error {
  border-color: #e74c3c;
  background: rgba(231, 76, 60, 0.05);
}

.skill-input.current {
  /* 保留旧样式 */
}

.skill-thresholds {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.threshold {
  font-size: 24rpx;
  color: var(--color-text-sub);
  min-width: 36rpx;
  text-align: center;
}

.threshold-sep {
  font-size: 20rpx;
  color: #ccc;
}

/* 顶部表头提示 */
.skills-header-hint {
  display: flex;
  justify-content: flex-end;
  font-size: 24rpx;
  color: #bbb;
  padding: 0 12rpx;
  margin-bottom: 8rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(245, 245, 240, 0.95);
  backdrop-filter: blur(10px);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 1000;
}

.bottom-btns {
  display: flex;
  gap: 20rpx;
}

.btn-random {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.dice-icon {
  width: 36rpx;
  height: 36rpx;
  filter: drop-shadow(0 0 0 var(--color-primary-dark));
}

.btn-save {
  flex: 2;
}

.save-warning {
  text-align: center;
  font-size: 24rpx;
  color: #e74c3c;
  margin-bottom: 12rpx;
}

.btn-disabled {
  opacity: 0.5;
}
