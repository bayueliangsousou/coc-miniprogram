<view class="skills-page">

  <!-- 技能点数面板（固定在顶部） -->
  <view class="points-panel">
    <!-- 职业技能点数 -->
    <view class="points-section occ-section">
      <text class="points-title">职业技能</text>
      <view class="points-numbers">
        <text class="points-remain {{points.occRemaining < 0 ? 'points-negative' : ''}}">{{points.occRemaining}}</text>
        <text class="points-slash">/</text>
        <text class="points-total">{{points.occTotal}}</text>
      </view>
      <text class="points-formula">{{pointFormula}}</text>
      <view class="points-bar-wrap">
        <view class="points-bar-fill occ-fill" style="width: {{points.occUsed / points.occTotal * 100}}%"></view>
      </view>
    </view>

    <!-- 兴趣技能点数 -->
    <view class="points-section int-section">
      <text class="points-title">兴趣技能</text>
      <view class="points-numbers">
        <text class="points-remain {{points.intRemaining < 0 ? 'points-negative' : ''}}">{{points.intRemaining}}</text>
        <text class="points-slash">/</text>
        <text class="points-total">{{points.intTotal}}</text>
      </view>
      <text class="points-formula">EDU×2</text>
      <view class="points-bar-wrap">
        <view class="points-bar-fill int-fill" style="width: {{points.intUsed / points.intTotal * 100}}%"></view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="skills-scroll" scroll-into-view="{{scrollToSkill}}" scroll-with-animation>

  <!-- 搜索 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索技能..." value="{{searchText}}" bindinput="onSearch" confirm-type="search"/>
    <view class="search-nav" wx:if="{{searchMatches.length > 0}}" bindtap="onSearchNext">
      <text class="search-count">{{searchIndex + 1}}/{{searchMatches.length}}</text>
    </view>
    <view class="search-nav search-nav-empty" wx:elif="{{searchText}}">
      <text class="search-count">0/0</text>
    </view>
  </view>

  <!-- 职业技能提示 -->
  <view class="occ-hint" wx:if="{{occupationSkills.length > 0}}">
    <text>★ 金色标记为职业技能</text>
  </view>

  <!-- 社会信用评级（放在调查分类上方） -->
  <view class="credit-rating-section" wx:if="{{creditRatingRange}}">
    <view class="credit-rating-header">
      <text class="credit-rating-title {{creditRatingError ? 'credit-rating-error-text' : ''}}">社会信用评级</text>
      <view class="credit-rating-right">
        <input
          class="credit-rating-input {{creditRatingError ? 'credit-rating-input-error' : ''}}"
          type="number"
          value="{{creditRatingValue}}"
          bindinput="onCreditRatingInput"
          bindblur="onCreditRatingBlur"
          placeholder="0"
        />
        <text class="credit-rating-range {{creditRatingError ? 'credit-rating-error-text' : ''}}">{{creditRatingRange[0]}} — {{creditRatingRange[1]}}</text>
      </view>
    </view>
  </view>

  <!-- 技能分类列表 -->
  <view wx:for="{{skillCategories}}" wx:key="category">
    <!-- 分类标题 -->
    <view class="cat-header" data-category="{{item.category}}" bindtap="onToggleCategory">
      <text class="cat-name">{{item.category}}<text class="cat-limit" wx:if="{{item.limitText}}">{{item.limitText}}</text></text>
      <text class="cat-count">{{item.skills.length}} 项</text>
      <text class="cat-arrow">{{expandedCategories[item.category] ? '▾' : '▸'}}</text>
    </view>

    <!-- 技能行 -->
    <view wx:if="{{expandedCategories[item.category]}}">
      <block wx:for="{{item.skills}}" wx:key="name" wx:for-item="sk">
        <!-- 搜索过滤 -->
        <view
          id="skill-{{sk.name}}"
          class="skill-row {{sk.displayAsOcc ? 'is-occ' : ''}} {{searchMatches[searchIndex] === sk.name ? 'skill-highlight' : ''}}"
          wx:if="{{!searchText || sk.name.indexOf(searchText) !== -1}}"
        >
          <view class="skill-name-wrap">
            <text class="occ-dot" wx:if="{{sk.displayAsOcc}}">★</text>
            <text class="skill-name {{sk.displayAsOcc ? 'occ-skill-name' : ''}}">{{sk.name}}</text>
            <input
              wx:if="{{sk.name === '其他语言'}}"
              class="language-name-input"
              placeholder="语言名"
              value="{{sk.languageName}}"
              data-name="{{sk.name}}"
              bindinput="onLanguageNameInput"
            />
            <text class="skill-base">基础{{sk.baseValue}}</text>
            <!-- 删除按钮（仅自定义技能） -->
            <view class="skill-delete" wx:if="{{sk.isCustom}}" catchtap="onDeleteCustomSkill" data-name="{{sk.name}}">
              <text class="delete-icon">删除</text>
            </view>
          </view>
          <view class="skill-inputs">
            <input
              class="skill-input current {{sk.displayAsOcc ? 'input-occ' : 'input-int'}} {{invalidSkills[sk.name] ? 'input-error' : ''}}"
              type="number"
              value="{{sk.current}}"
              data-name="{{sk.name}}"
              bindinput="onSkillInput"
              bindblur="onSkillBlur"
              bindfocus="onSkillFocus"
              placeholder="0"
              adjust-position="{{false}}"
            />
            <view class="skill-thresholds">
              <text class="threshold">{{sk.hard}}</text>
              <text class="threshold-sep">/</text>
              <text class="threshold">{{sk.extreme}}</text>
            </view>
          </view>
        </view>
      </block>

    </view>
  </view>

  <!-- 表头说明（悬浮） -->
  <view class="skills-header-hint">
    <text>当前值</text>
    <text style="margin-left:20rpx">困难 / 极难</text>
  </view>

  </scroll-view>

</view>

<!-- 底部保存 -->
<view class="bottom-bar safe-bottom">
  <view class="bottom-btns">
    <button class="btn btn-ghost btn-random" bindtap="onRandomDistribute">
      <text>随机</text>
    </button>
    <button class="btn btn-ghost btn-new-skill" bindtap="onShowNewSkill">
      <text>新技能</text>
    </button>
    <button class="btn btn-primary btn-save" bindtap="onSave">保存技能</button>
  </view>
</view>

<!-- 新建技能弹窗 -->
<view class="modal-mask" wx:if="{{showNewSkillModal}}" bindtap="onCancelNewSkill">
  <view class="modal-box" catchtap="preventBubble">
    <view class="modal-title">新建职业技能</view>
    <view class="new-skill-row">
      <input
        class="new-skill-name-input"
        placeholder="技能名称"
        value="{{newSkillName}}"
        bindinput="onNewSkillNameInput"
        focus="{{showNewSkillModal}}"
      />
      <input
        class="new-skill-val-input"
        type="number"
        placeholder="数值"
        value="{{newSkillValue}}"
        bindinput="onNewSkillValueInput"
        bindconfirm="onConfirmNewSkill"
      />
    </view>
    <view class="new-skill-hint">新建技能值将占用职业技能点数</view>
    <view class="modal-btns">
      <button class="btn btn-ghost" bindtap="onCancelNewSkill">取消</button>
      <button class="btn btn-primary" bindtap="onConfirmNewSkill">保存</button>
    </view>
  </view>
</view>
