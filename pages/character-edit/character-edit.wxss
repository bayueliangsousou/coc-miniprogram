/* pages/character-edit/character-edit.wxss */

.edit-page {
  height: 100vh;
}

/* ── 基本信息表单 ── */

/* 基本信息表单 - 提高优先级 */
.character-edit .form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.character-edit .form-row:last-of-type {
  border-bottom: none;
}

.character-edit .form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: var(--color-text-sub);
  flex-shrink: 0;
  line-height: 1;
}

.form-input {
  flex: 1;
  height: 64rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.character-edit .form-value-touch {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
}

.character-edit .form-value {
  font-size: 28rpx;
  color: var(--color-primary-dark);
  font-weight: 600;
  line-height: 1;
}

.character-edit .form-placeholder {
  font-size: 28rpx;
  color: #bbb;
  line-height: 1;
}

.character-edit .form-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
  line-height: 1;
}

/* 年龄/性别/出生地三列 */
.info-row3 {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
}

.info-cell {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-cell:nth-child(1),
.info-cell:nth-child(2) {
  flex: 1;
}

.info-cell:nth-child(3) {
  flex: 2;
}

.info-label {
  font-size: 28rpx;
  color: var(--color-text-sub);
}

.info-input {
  height: 64rpx;
  background: #fafafa;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text);
  padding: 0;
}

.info-picker {
  height: 64rpx;
  background: #fafafa;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  cursor: pointer;
  position: relative;
  z-index: 1;
}

.info-picker .picker-value {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.info-picker .picker-value .placeholder {
  color: #bbb;
}

/* ── 随机按钮 ── */
.btn-roll-all {
  font-size: 26rpx;
  color: #c9a84c;
  background: rgba(201, 168, 76, 0.15);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
  margin-left: auto;
  border: 1rpx solid rgba(201, 168, 76, 0.3);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.btn-roll-all .roll-icon {
  width: 28rpx;
  height: 28rpx;
  filter: drop-shadow(0 0 0 var(--color-primary-dark));
}

.btn-roll-all text {
  color: var(--color-primary-dark);
}

/* ── 属性九宫格（与完成页统一） ── */
.attr-grid9 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.attr-cell {
  background: #f8f7f3;
  border-radius: var(--radius-sm);
  padding: 16rpx 10rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.attr-cell-title {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.attr-cell-en {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1;
}

.attr-cell-cn {
  font-size: 28rpx;
  color: var(--color-text-sub);
}

.attr-cell-input-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  width: 100%;
}

.attr-cell-input {
  width: 60px;
  height: 40px;
  background: #fff;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-primary-dark);
  padding: 0;
}

.roll-dot {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.roll-dot .roll-dot-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 0 0 var(--color-primary-dark));
}

/* 第四行：移动/体格/伤害修正（与完成页统一浅色） */
.attr-row4 {
  display: flex;
  gap: 12rpx;
}

.attr-row4-item {
  flex: 1;
  background: #f8f7f3;
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
  gap: 4rpx;
}

.row4-val {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--color-primary-dark);
  line-height: 1.2;
}

.row4-lbl {
  font-size: 28rpx;
  color: var(--color-text-sub);
}

/* ── 武器设置 ── */
.weapons-list {
  margin-bottom: 16rpx;
}

.weapons-empty {
  font-size: 24rpx;
  color: #bbb;
  padding: 16rpx 0;
  text-align: center;
}

.weapon-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.weapon-row:last-child {
  border-bottom: none;
}

.weapon-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weapon-name {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

.weapon-skill {
  font-size: 28rpx;
  color: var(--color-primary-dark);
  background: rgba(201,168,76,0.12);
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
}

.weapon-damage {
  font-size: 28rpx;
  color: #555;
}

.weapon-del {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e74c3c;
  font-size: 36rpx;
  font-weight: 700;
}

.add-weapon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border: 2rpx dashed var(--color-primary);
  border-radius: var(--radius-sm);
  color: var(--color-primary-dark);
  font-size: 24rpx;
  font-weight: 600;
}

.add-weapon-btn:active {
  background: rgba(201,168,76,0.06);
}

/* ── 快捷导航 ── */
.quick-nav {
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.nav-btn {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

.nav-btn:active {
  background: #f5f5f0;
}

.nav-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.nav-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.nav-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.nav-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.nav-sub {
  font-size: 28rpx;
  color: var(--color-primary-dark);
}

.nav-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* ── 底部固定按钮 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: rgba(245, 245, 240, 0.95);
  backdrop-filter: blur(10px);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* ── 武器弹窗 ── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 900;
}

.weapon-modal {
  position: fixed;
  left: 40rpx; right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 40rpx;
  z-index: 901;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.2);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 32rpx;
  text-align: center;
}

.modal-form-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.modal-label {
  font-size: 24rpx;
  color: var(--color-text-sub);
  width: 140rpx;
  flex-shrink: 0;
}

.modal-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0 16rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: #fafafa;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.modal-btn-cancel {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text-sub);
}

.modal-btn-confirm {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #c9a84c, #8b5e1a);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* ── 武器输入表单（内联） ── */
.weapon-form-section {
  background: #f8f7f3;
  border-radius: var(--radius-sm);
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid var(--color-border);
}

.weapon-form-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
  gap: 8rpx;
}

.weapon-form-row2 {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.weapon-form-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.weapon-form-label {
  font-size: 24rpx;
  color: var(--color-text-sub);
  flex-shrink: 0;
}

.weapon-form-picker {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.weapon-form-picker-value {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: var(--color-text);
}

.weapon-form-picker-value .placeholder {
  color: #bbb;
}

.weapon-form-input {
  height: 72rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0 16rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: #fff;
}

.weapon-form-btns {
  display: flex;
  gap: 16rpx;
}

.weapon-form-btn-cancel {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text-sub);
  background: #fff;
}

.weapon-form-btn-confirm {
  flex: 2;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #c9a84c, #8b5e1a);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.weapon-form-btn-cancel:active { opacity: 0.7; }
.weapon-form-btn-confirm:active { opacity: 0.85; }

/* 伤害值显示 */
.weapon-damage-display {
  height: 72rpx;
  background: #f0f0f0;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}

.damage-value {
  font-size: 28rpx;
  color: var(--color-primary-dark);
  font-weight: 600;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

/* ── 武器展示模式（保存后） ── */
.weapon-display-section {
  padding: 16rpx 0;
}

.weapon-selector-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.weapon-selector-label {
  font-size: 28rpx;
  color: var(--color-text-sub);
  flex-shrink: 0;
}

.weapon-picker {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  background: #fafafa;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

.weapon-picker-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: var(--color-text);
}

.weapon-picker-value .placeholder {
  color: #bbb;
}

.weapon-detail-display {
  background: #f8f7f3;
  border-radius: var(--radius-sm);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.weapon-detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-label {
  font-size: 24rpx;
  color: var(--color-text-sub);
}

.detail-value {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}
