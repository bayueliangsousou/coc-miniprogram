<view class="page">

  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <text class="nav-arrow">‹</text>
    </view>
    <text class="nav-title">加入房间</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 房间号输入 -->
  <view class="section">
    <text class="section-title">输入房间号</text>
    <view class="room-code-input">
      <input 
        class="code-input {{error ? 'error' : ''}}"
        type="text"
        maxlength="6"
        placeholder="4位数字"
        value="{{roomCode}}"
        bindinput="onRoomCodeInput"
      />
    </view>
    <text class="error-text" wx:if="{{error}}">{{error}}</text>
  </view>

  <!-- 选择角色 -->
  <view class="section">
    <text class="section-title">选择要加入的角色</text>
    
    <view wx:if="{{characters.length === 0}}" class="empty-state">
      <text>暂无角色</text>
      <text class="empty-hint">请先创建角色后再加入房间</text>
    </view>

    <view class="character-list">
      <view 
        class="character-item {{selectedCharacterId === item.id ? 'selected' : ''}}"
        wx:for="{{characters}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onCharacterSelect"
      >
        <view class="char-radio">
          <view class="radio-inner" wx:if="{{selectedCharacterId === item.id}}"></view>
        </view>
        <view class="char-info">
          <text class="char-name">{{item.name || '未命名'}}</text>
          <text class="char-occ">{{item.occupation || '未选择职业'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加入按钮 -->
  <view class="action-area">
    <button 
      class="join-btn {{isJoining ? 'loading' : ''}}"
      bindtap="onJoinRoom"
      disabled="{{isJoining || !roomCode || !selectedCharacterId}}"
    >
      <text wx:if="{{!isJoining}}">确认加入</text>
      <text wx:else>加入中...</text>
    </button>
  </view>

  <!-- 提示 -->
  <view class="tips">
    <text class="tip-text">• 向KP索要房间号</text>
    <text class="tip-text">• 房间号由6位字母和数字组成</text>
    <text class="tip-text">• 加入后可与桌面端同步状态</text>
  </view>

</view>
