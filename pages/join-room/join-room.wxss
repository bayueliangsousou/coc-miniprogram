/* pages/join-room/join-room.wxss */

.page {
  min-height: 100vh;
  background-color: #f5f5f0;
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 30rpx;
  background-color: #252533;
  color: white;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow {
  font-size: 48rpx;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 500;
}

.nav-placeholder {
  width: 60rpx;
}

/* 区块 */
.section {
  margin: 30rpx;
  padding: 30rpx;
  background-color: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

/* 房间号输入 */
.room-code-input {
  display: flex;
  justify-content: center;
}

.code-input {
  width: 360rpx;
  height: 100rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 48rpx;
  font-family: 'Courier New', monospace;
  text-align: center;
  letter-spacing: 8rpx;
  text-transform: uppercase;
  background-color: #fafafa;
}

.code-input.error {
  border-color: #e74c3c;
}

.error-text {
  display: block;
  text-align: center;
  color: #e74c3c;
  font-size: 24rpx;
  margin-top: 16rpx;
}

/* 角色列表 */
.character-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.character-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #fafafa;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.character-item.selected {
  background-color: #e8f4fd;
  border-color: #3498db;
}

.char-radio {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.character-item.selected .char-radio {
  border-color: #3498db;
}

.radio-inner {
  width: 24rpx;
  height: 24rpx;
  background-color: #3498db;
  border-radius: 50%;
}

.char-info {
  flex: 1;
}

.char-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.char-occ {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #888;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  margin-top: 12rpx;
}

/* 操作区域 */
.action-area {
  padding: 0 30rpx;
  margin-top: 40rpx;
}

.join-btn {
  width: 100%;
  height: 96rpx;
  background-color: #3498db;
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.join-btn[disabled] {
  background-color: #bdc3c7;
}

.join-btn.loading {
  background-color: #95a5a6;
}

/* 提示 */
.tips {
  padding: 30rpx;
  margin-top: 40rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: #888;
  line-height: 1.8;
}
