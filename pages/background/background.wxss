/* pages/background/background.wxss */

.intro-card {
  background: rgba(201, 168, 76, 0.08);
  border-left: 6rpx solid var(--color-primary);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.intro-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
  font-style: italic;
}

.bg-textarea {
  width: 100%;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.7;
  background: #fafafa;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 20rpx;
}

.bg-textarea:focus {
  border-color: var(--color-primary);
  background: #fff;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: rgba(245, 245, 240, 0.95);
  backdrop-filter: blur(10px);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
}
