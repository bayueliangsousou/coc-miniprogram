<view class="test-page">
  <text class="title">调查员名册</text>
  <text class="info">角色数量: {{characters.length}}</text>
  
  <block wx:if="{{characters.length === 0}}">
    <text class="empty">暂无角色，点击下方按钮创建</text>
  </block>
  
  <block wx:else>
    <view wx:for="{{characters}}" wx:key="id" class="item" bindtap="onCardTap" data-id="{{item.id}}">
      <text class="char-name">{{item.name || '未命名'}}</text>
      <text class="char-occ">{{item.occupation || '无职业'}}</text>
    </view>
  </block>
  
  <button class="btn" bindtap="onAdd">创建新角色</button>
</view>
