.test-page {
  padding: 40rpx;
  background: #f5f5f0;
  min-height: 100vh;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 30rpx;
}

.info {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.empty {
  font-size: 32rpx;
  color: #999;
  margin-top: 60rpx;
}

.item {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.char-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.char-occ {
  font-size: 24rpx;
  color: #888;
  background: rgba(201, 168, 76, 0.15);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.btn {
  margin-top: 40rpx;
  background: #c9a84c;
  color: #fff;
}
