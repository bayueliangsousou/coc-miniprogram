<view class="page-container" catchtap="onPageTap">

  <!-- ===== 背景图 ===== -->
  <image class="page-bg" src="/assets/images/bg.jpg" mode="aspectFill"/>

  <!-- ===== 自定义导航栏 ===== -->
  <view class="custom-nav" style="height: {{statusBarHeight + navHeight}}px;">
    <view class="custom-nav-title" style="top: {{statusBarHeight}}px; height: {{navHeight}}px;">
      <text>调查员名册</text>
    </view>
  </view>
  <scroll-view scroll-y class="main-scroll" enhanced style="height:100vh" bounces="{{false}}">

  <view style="height: {{statusBarHeight + navHeight}}px;"></view>

  <!-- 空状态 -->
  <block wx:if="{{characters.length === 0}}">
    <view class="empty-state">
      <view class="empty-icon">📜</view>
      <text class="empty-title">尚无调查员</text>
      <text class="empty-desc">点击底部"＋"按钮创建第一个角色卡</text>
    </view>
  </block>

  <!-- 角色卡列表 -->
  <block wx:else>
    <view class="character-list">
      <!-- 每张卡片用 swipe-wrapper 包裹 -->
      <view
        class="swipe-wrapper"
        wx:for="{{characters}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-index="{{index}}"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd"
      >
        <!-- 卡片主体（滑动的内容） -->
        <view
          class="character-card"
          style="transform: translateX({{swipeId === item.id ? -120 : 0}}rpx); transition: transform {{swipeId === item.id ? '0s' : '0.3s'}} ease;"
          data-id="{{item.id}}"
          bindtap="onCardTap"
        >
          <!-- SVG 外边框背景 -->
          <image class="card-border-bg" src="/assets/images/card-border.svg" mode="scaleToFill"/>

          <view class="card-v2-inner">
            <!-- 上半部分：信息区 -->
            <view class="card-v2-top">
              <view class="card-v2-header">
                <text class="card-v2-name">{{item.name || '未命名调查员'}}</text>
                <text class="card-v2-date" wx:if="{{item.createdAt}}">{{item.createdAt}}</text>
              </view>
              <view class="card-v2-meta">
                <text wx:if="{{item.age}}">{{item.age}}岁</text>
                <text wx:if="{{item.age && item.gender}}"> · </text>
                <text wx:if="{{item.gender}}">{{item.gender}}</text>
                <text wx:if="{{(item.age || item.gender) && item.occupation}}"> · </text>
                <text wx:if="{{item.occupation}}">{{item.occupation}}</text>
              </view>
            </view>

            <!-- 下半部分：属性区 -->
            <view class="card-v2-bottom">
              <view class="card-v2-stat">
                <text class="card-v2-stat-lbl">HP</text>
                <text class="card-v2-stat-current">{{item.combat.hpCurrent || item.derived.hp}}</text>
                <text class="card-v2-stat-sep">/</text>
                <text class="card-v2-stat-max">{{item.derived.hp}}</text>
              </view>
              <view class="card-v2-stat">
                <text class="card-v2-stat-lbl">SAN</text>
                <text class="card-v2-stat-current">{{item.combat.sanCurrent || item.derived.sanStart}}</text>
                <text class="card-v2-stat-sep">/</text>
                <text class="card-v2-stat-max">{{item.derived.sanStart}}</text>
              </view>
              <view class="card-v2-stat">
                <text class="card-v2-stat-lbl">MP</text>
                <text class="card-v2-stat-current">{{item.combat.mpCurrent || item.derived.mp}}</text>
                <text class="card-v2-stat-sep">/</text>
                <text class="card-v2-stat-max">{{item.derived.mp}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 删除按钮（藏在右侧，滑动后露出） -->
        <view class="swipe-delete-btn" catchtap="onDeleteTap" data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </view>

      <!-- 提示文字（仅列表有内容时显示） -->
      <view wx:if="{{index === characters.length - 1}}" class="list-footer-tip">
        <text>右滑可删除角色 · 最多支持创建5个角色卡</text>
      </view>
    </view>
  </block>

  </scroll-view>

  <!-- ===== 骰子工具组件 ===== -->
  <dice-tool id="diceTool"
    fab-bottom-default="200"
    fab-bg="#f5f5f0"
    throw-btn-bg="linear-gradient(135deg, #e8b830, #c89a20)"
    bottom-limit="150"
    bind:close="onDiceClose"
  />

  <!-- 吸底按钮栏：新建调查员(3/4) + 我的(1/4) -->
  <view class="bottom-bar">
    <view class="bottom-bar-create" bindtap="onCreateTap">
      <text class="bottom-bar-icon">+</text>
      <text>新建调查员</text>
    </view>
    <view class="bottom-bar-mine" bindtap="onMineTap">
      <text>我的</text>
    </view>
  </view>

  <!-- 我的弹窗 -->
  <view class="mine-modal-mask" wx:if="{{showMineModal}}" bindtap="onMineModalClose">
    <view class="mine-modal" catchtap="">
      <view class="mine-modal-title">账号管理</view>
      <view class="mine-modal-info">
        <text class="mine-modal-label">当前账号</text>
        <text class="mine-modal-value">{{userInfo.nickName || '未知用户'}}</text>
      </view>
      <view class="mine-modal-btn logout" bindtap="onLogoutTap">退出登录</view>
      <view class="mine-modal-btn close" bindtap="onMineModalClose">关闭</view>
    </view>
  </view>

</view>
