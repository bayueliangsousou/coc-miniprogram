/* pages/index/index.wxss */

/* ===== 页面整体：Flex 纵向布局 ===== */
.page-container {
  min-height: 100vh;      /* 改掉 height:100vh，避免 Flex 计算异常 */
  display: flex;
  flex-direction: column;
  position: relative;
  background: #f5f5f0;
  padding: 0;             /* 覆盖 app.wxss 全局 24rpx padding */
}

/* 全屏背景图 */
.page-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}

/* ===== 自定义导航栏（固定高度，不参与 Flex 伸缩） ===== */
.custom-nav {
  position: relative;
  z-index: 100;
  background: transparent;
  flex-shrink: 0;
}

.custom-nav-title {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 190rpx;
  box-sizing: border-box;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  pointer-events: auto;
}

/* ===== 主体滚动区：Flex 撑满剩余空间 ===== */
.main-scroll {
  flex: 1;
  height: 0;           /* 关键：让 scroll-view 在 Flex 里正确收缩 */
  min-height: 0;
  padding: 20rpx 32rpx 0;
  box-sizing: border-box;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon { font-size: 120rpx; opacity: 0.3; margin-bottom: 30rpx; }
.empty-title { font-size: 36rpx; font-weight: bold; color: #252533; margin-bottom: 16rpx; }
.empty-desc { font-size: 24rpx; color: #888; }

/* ===== 角色列表 ===== */
.character-list {
  padding-bottom: 200rpx; /* 给底部按钮栏留空间 */
}

/* ===== 角色卡片 ===== */
.character-card {
  position: relative;
  width: 100%;
  border-radius: var(--radius-md);
  overflow: hidden;
}

/* 背景图：由图片自然撑开卡片高度 */
.card-bg {
  width: 100%;
  height: auto;
  display: block;
}

/* 信息区：绝对定位在卡片顶部 */
.card-top {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 40rpx 32rpx 16rpx;
  z-index: 2;
  max-height: 45%;          /* 限制最大高度，防止与底部属性区重叠 */
  overflow: hidden;
  box-sizing: border-box;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.card-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #252533;
  font-family: 'Special Elite';
}

.card-date {
  font-size: 26rpx;
  color: #666;
  font-family: 'Special Elite';
}

.card-meta {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  max-height: 60rpx;       /* 职业等信息最多两行 */
  overflow: hidden;
}

/* 属性区：绝对定位在卡片底部 */
.card-stats {
  position: absolute;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 32rpx;
  z-index: 2;
}

.card-stat {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.card-stat-lbl {
  font-size: 28rpx;
  font-weight: 700;
  color: #252533;
  margin-right: 8rpx;
  font-family: 'Special Elite';
}

.card-stat-current {
  font-size: 40rpx;
  font-weight: 800;
  color: #252533;
  line-height: 1;
  font-family: 'Special Elite';
}

.card-stat-sep {
  font-size: 24rpx;
  color: #666;
  font-family: 'Special Elite';
}

.card-stat-max {
  font-size: 28rpx;
  color: #666;
  font-family: 'Special Elite';
}

/* ===== 列表底部提示 ===== */
.list-footer-tip {
  text-align: center;
  padding: 20rpx 0 8rpx;
  font-size: 22rpx;
  color: #888;
}

/* ===== 底部按钮栏（正常模式） ===== */
.bottom-bar {
  box-sizing: border-box;
  flex-shrink: 0;
  z-index: 50;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #252533;
}

.bottom-bar-create {
  flex: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #c9a84c;
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.bottom-bar-create:active { opacity: 0.85; transform: scale(0.98); }
.bottom-bar-create-disabled { background: rgba(201,168,76,0.5); }

.bottom-bar-icon {
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
}

.bottom-bar-mine {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #c9a84c;
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.bottom-bar-mine:active { opacity: 0.85; transform: scale(0.98); }

/* ===== 删除模式底部栏 ===== */
.bottom-bar-delete {
  box-sizing: border-box;
  flex-shrink: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #e74c3c;
  height: calc(108rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.delete-hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  flex-shrink: 0;
}

.bottom-bar-delete-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.25);
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.bottom-bar-delete-btn:active { opacity: 0.85; transform: scale(0.97); }

.delete-cancel {
  flex-shrink: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  color: rgba(255,255,255,0.9);
  font-size: 28rpx;
}

/* ===== 我的弹窗 ===== */
.mine-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mine-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.2);
}

.mine-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #252533;
  text-align: center;
  margin-bottom: 36rpx;
}

.mine-modal-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 36rpx;
  border-top: 1rpx solid #eee;
  border-bottom: 1rpx solid #eee;
}

.mine-modal-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.mine-modal-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.mine-modal-btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.mine-modal-btn.logout { background: #e74c3c; color: #fff; }
.mine-modal-btn.logout:active { opacity: 0.85; }
.mine-modal-btn.close { background: #f0f0f0; color: #888; }
.mine-modal-btn.close:active { opacity: 0.85; }
