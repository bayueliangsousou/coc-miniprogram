/* pages/index/index.wxss */

.page-container {
  min-height: 100vh;
  background: #202031;
  padding: 24rpx;
  box-sizing: border-box;
}

.character-list {
  padding-bottom: 200rpx;
}

/* ── 列表底部提示 ── */
.list-footer-tip {
  text-align: center;
  padding: 16rpx 0 8rpx;
  font-size: 22rpx;
  color: #bbb;
}

/* ── 滑动容器 ── */
.swipe-wrapper {
  position: relative;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: var(--radius-md);
}

/* ── 角色卡 ── */
.character-card {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 1;
  will-change: transform;
}

/* ── 删除按钮（右侧隐藏区） ── */
.swipe-delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 120rpx;
  background: #c0392b;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
}

.swipe-delete-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* ── 卡片内容 ── */
.card-accent {
  width: 10rpx;
  background: linear-gradient(180deg, #c9a84c, #8b5e1a);
  flex-shrink: 0;
}

.card-body {
  flex: 1;
  padding: 28rpx 28rpx 28rpx 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.card-occupation {
  font-size: 28rpx;
}

.card-meta {
  font-size: 28rpx;
  color: var(--color-text-sub);
  margin-bottom: 20rpx;
}

.card-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background: #f8f7f3;
  border-radius: 8rpx;
  width: 110px;
  height: 40px;
  gap: 8rpx;
  box-sizing: border-box;
}

.stat-lbl {
  font-size: 24rpx;
  color: var(--color-text-sub);
  line-height: 1;
}

.stat-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1;
}

/* ── 空状态 ── */
.empty-state {
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #888;
}

/* ============================================================
   骰子叠加层
   ============================================================ */
.dice-fab {
  position: fixed;
  width: 100rpx;
  height: 100rpx;
  background: #f5f5f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  z-index: 20;
}

.dice-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
}
.dice-overlay.visible {
  display: block;
}

.dice-canvas {
  width: 100%;
  height: 100%;
}

/* 骰子底部控制栏 - Grid 4列 + 投掷按钮跨两行 */
.dice-controls {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 130;
  display: grid;
  grid-template-columns: repeat(4, 1fr) auto;
  grid-template-rows: repeat(2, auto);
  gap: 8px;
  padding: 6px 12px 20px;
  align-items: center;
  background-color: #1a1a1a;
}

.dice-btn-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dice-btn {
  background-color: rgba(60, 60, 80, 0.9);
  color: #ffffff;
  font-size: 14px;
  font-weight: bold;
  padding: 2px 8px;
  border-radius: 6px;
  border: 1px solid rgba(100, 100, 130, 0.5);
  min-width: 40px;
  text-align: center;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
  width: 100%;
  height: 40px;
  line-height: 36px;
}

.dice-btn:active {
  background-color: rgba(80, 80, 110, 0.9);
  transform: scale(0.95);
}

/* 骰子数量 tag */
.dice-count {
  position: absolute;
  top: -6px;
  right: -6px;
  background-color: #ff4444;
  color: #ffffff;
  font-size: 11px;
  font-weight: bold;
  min-width: 16px;
  height: 16px;
  line-height: 16px;
  text-align: center;
  border-radius: 8px;
  padding: 0 4px;
}

/* 右侧投掷区域 */
.throw-area {
  grid-column: 5;
  grid-row: 1 / 3;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 4px;
}
.throw-collapse {
  color: rgba(255, 255, 255, 0.45);
  font-size: 20rpx;
  text-align: center;
  padding: 4rpx 0;
}
/* 投掷按钮 */
.throw-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8b830, #c89a20);
  color: #1a1a2e;
  font-size: 18px;
  font-weight: bold;
  padding: 0 20px;
  border-radius: 12px;
  box-shadow: 0 4px 12px rgba(232, 184, 48, 0.3);
  height: 66px;
}
.throw-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2px 8px rgba(232, 184, 48, 0.2);
}
.throw-btn.disabled {
  opacity: 0.4;
}

/* 结果卡片 */
.dice-result-panel {
  position: fixed;
  top: 120rpx;
  left: 50%;
  margin-left: -300rpx;
  width: 600rpx;
  z-index: 140;
  background: rgba(22, 22, 38, 0.92);
  border-radius: 20rpx;
  padding: 24rpx 24rpx;
  display: flex;
  flex-direction: row;
  box-sizing: border-box;
}
.drp-left {
  width: 400rpx;
  flex-shrink: 0;
  display: flex;
  flex-wrap: wrap;
  align-content: flex-start;
}
.drp-item {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  width: 100rpx;
  flex-shrink: 0;
  margin-bottom: 6rpx;
}
.drpi-type {
  color: #999;
  font-size: 26rpx;
  margin-right: 4rpx;
  line-height: 1.3;
}
.drpi-val {
  color: #e8b830;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1.3;
}
.drp-divider {
  width: 2rpx;
  margin: 0 16rpx;
  background: rgba(255, 255, 255, 0.12);
  flex-shrink: 0;
}
.drp-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
}
.drpr-label {
  color: #999;
  font-size: 26rpx;
}
.drpr-num {
  color: #e8b830;
  font-size: 52rpx;
  font-weight: bold;
}

/* ── 吸底按钮栏 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #202031;
}

.bottom-bar-create {
  flex: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #A98948;
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.bottom-bar-create:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.bottom-bar-icon {
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
}

.bottom-bar-mine {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #A98948;
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.bottom-bar-mine:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ── 我的弹窗 ── */
.mine-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mine-modal {
  width: 580rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

.mine-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 36rpx;
}

.mine-modal-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 36rpx;
  border-top: 1rpx solid #eee;
  border-bottom: 1rpx solid #eee;
}

.mine-modal-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.mine-modal-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.mine-modal-btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.mine-modal-btn.logout {
  background: #e74c3c;
  color: #fff;
}

.mine-modal-btn.logout:active {
  opacity: 0.85;
}

.mine-modal-btn.close {
  background: #f0f0f0;
  color: #666;
}

.mine-modal-btn.close:active {
  opacity: 0.85;
}
