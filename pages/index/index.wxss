/* pages/index/index.wxss */

.page-container {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 0;
}

.main-scroll {
  padding: 24rpx;
  padding-top: 0;
  box-sizing: border-box;
}

/* ── 背景图 ── */
.page-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: -1;
}

/* ── 自定义导航栏 ── */
.custom-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  background: transparent;
}

.custom-nav-title {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 190rpx;
  box-sizing: border-box;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  pointer-events: auto;
}

.character-list {
  padding-bottom: 200rpx;
}

/* ── 列表底部提示 ── */
.list-footer-tip {
  text-align: center;
  padding: 16rpx 0 8rpx;
  font-size: 22rpx;
  color: #888888;
}

/* ── 滑动容器 ── */
.swipe-wrapper {
  position: relative;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: var(--radius-md);
}

/* ── 角色卡 v2（档案卡风格） ── */
.character-card {
  position: relative;
  background: none;
  padding: 0;
  overflow: visible;
  z-index: 1;
  will-change: transform;
}

/* 内部容器 */
.card-v2-inner {
  position: relative;
  z-index: 2;
  background: #F0ECE4;
  border-radius: 10rpx;
  overflow: hidden;
}

/* 上半部分：信息区 */
.card-v2-top {
  padding: 24rpx 28rpx 20rpx;
}

.card-v2-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-v2-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #252533;
  font-family: 'Special Elite';
}

.card-v2-date {
  font-size: 26rpx;
  color: #888888;
  font-family: 'Special Elite';
}

.card-v2-meta {
  font-size: 26rpx;
  color: #888888;
}

/* 下半部分：属性区 */
.card-v2-bottom {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: url('https://mastermind-5grqnmdu0d3a7d81-1404084982.tcloudbaseapp.com/mingce.png') center/cover no-repeat #777C68;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.card-v2-stat {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.card-v2-stat-lbl {
  font-size: 28rpx;
  font-weight: 700;
  color: #000;
  margin-right: 8rpx;
  font-family: 'Special Elite';
}

.card-v2-stat-current {
  font-size: 40rpx;
  font-weight: 800;
  color: #000;
  line-height: 1;
  font-family: 'Special Elite';
}

.card-v2-stat-sep {
  font-size: 24rpx;
  color: #000;
  font-family: 'Special Elite';
}

.card-v2-stat-max {
  font-size: 28rpx;
  color: #000;
  font-family: 'Special Elite';
}

/* ── 删除按钮（右侧隐藏区） ── */
.swipe-delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 120rpx;
  background: #e74c3c;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
}

.swipe-delete-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* ── 空状态 ── */
.empty-state {
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #252533;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #888888;
}

/* ── 吸底按钮栏 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #252533;
}

.bottom-bar-create {
  flex: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #c9a84c;
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  gap: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.bottom-bar-create:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.bottom-bar-create-disabled {
  background: rgba(201, 168, 76, 0.5);
}

.bottom-bar-icon {
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
}

.bottom-bar-mine {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #c9a84c;
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.bottom-bar-mine:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ── 我的弹窗 ── */
.mine-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mine-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

.mine-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #252533;
  text-align: center;
  margin-bottom: 36rpx;
}

.mine-modal-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 36rpx;
  border-top: 1rpx solid #eee;
  border-bottom: 1rpx solid #eee;
}

.mine-modal-label {
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.mine-modal-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.mine-modal-btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.mine-modal-btn.logout {
  background: #e74c3c;
  color: #fff;
}

.mine-modal-btn.logout:active {
  opacity: 0.85;
}

.mine-modal-btn.close {
  background: #f0f0f0;
  color: #888888;
}

.mine-modal-btn.close:active {
  opacity: 0.85;
}
