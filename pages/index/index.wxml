<view class="page-container" catchtap="onPageTap">

  <!-- ===== 骰子模式叠加层 ===== -->
  <view class="dice-overlay {{diceMode ? 'visible' : ''}}">
    <!-- WebGL Canvas -->
    <canvas type="webgl" id="dice-canvas" class="dice-canvas"></canvas>
    
    <!-- 结果卡片 -->
    <cover-view class="dice-result-panel" wx:if="{{diceResults.length > 0}}">
      <cover-view class="drp-left">
        <cover-view class="drp-item" wx:for="{{diceResults}}" wx:key="id" wx:for-item="r">
          <cover-view class="drpi-type">{{r.type}}</cover-view>
          <cover-view class="drpi-val">{{r.value}}</cover-view>
        </cover-view>
      </cover-view>
      <cover-view class="drp-divider"></cover-view>
      <cover-view class="drp-right">
        <cover-view class="drpr-label">总值</cover-view>
        <cover-view class="drpr-num">{{diceTotalSum}}</cover-view>
      </cover-view>
    </cover-view>

    <!-- 关闭骰子 -->
  </view>

  <!-- ===== 骰子浮动按钮（打开/关闭一体） ===== -->
  <view
    wx:if="{{!diceMode}}"
    class="dice-fab"
    style="right: {{fabRight || 30}}rpx; bottom: {{fabBottom || 200}}rpx"
    bindtap="onDiceModeToggle"
    bindtouchstart="onFabTouchStart"
    bindtouchmove="onFabTouchMove"
    bindtouchend="onFabTouchEnd"
  >
    <text>{{diceMode ? '✕' : '🎲'}}</text>
  </view>

  <!-- ===== 骰子模式下的底部控制栏 ===== -->
  <view class="dice-controls" wx:if="{{diceMode}}">
    <block wx:for="{{diceTypes}}" wx:key="type">
      <view class="dice-btn-wrap" data-type="{{item.type}}" bindtap="onDiceBtnTap">
        <view class="dice-btn">{{item.label}}</view>
        <view class="dice-count" wx:if="{{diceCounts[item.type] > 0}}">{{diceCounts[item.type]}}</view>
      </view>
    </block>
    <!-- 右侧收起 + 投掷区域 -->
    <view class="throw-area" wx:if="{{diceMode}}">
      <view class="throw-collapse" bindtap="onDiceModeToggle">收起骰子</view>
      <view class="throw-btn {{diceHasDice ? '' : 'disabled'}}" bindtap="onDiceThrow">投掷</view>
    </view>
  </view>

  <!-- 空状态 -->
  <block wx:if="{{characters.length === 0}}">
    <view class="empty-state">
      <view class="empty-icon">📜</view>
      <text class="empty-title">尚无调查员</text>
      <text class="empty-desc">点击底部"＋"按钮创建第一个角色卡</text>
    </view>
  </block>

  <!-- 角色卡列表 -->
  <block wx:else>
    <view class="character-list">
      <!-- 每张卡片用 swipe-wrapper 包裹 -->
      <view
        class="swipe-wrapper"
        wx:for="{{characters}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-index="{{index}}"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd"
      >
        <!-- 卡片主体（滑动的内容） -->
        <view
          class="character-card"
          style="transform: translateX({{swipeId === item.id ? -120 : 0}}rpx); transition: transform {{swipeId === item.id ? '0s' : '0.3s'}} ease;"
          data-id="{{item.id}}"
          bindtap="onCardTap"
        >
          <!-- 左侧色条 -->
          <view class="card-accent"></view>

          <!-- 主体 -->
          <view class="card-body">
            <view class="card-header">
              <view class="card-name">{{item.name || '未命名调查员'}}</view>
              <view class="card-occupation tag">{{item.occupation || '未选职业'}}</view>
            </view>

            <view class="card-meta">
              <text wx:if="{{item.age}}">{{item.age}}岁</text>
              <text wx:if="{{item.gender}}"> · {{item.gender}}</text>
              <text wx:if="{{item.birthplace}}"> · {{item.birthplace}}</text>
            </view>

            <!-- 关键属性预览 -->
            <view class="card-stats">
              <view class="stat-item">
                <text class="stat-lbl">HP</text>
                <text class="stat-val">{{item.combat.hpCurrent || item.derived.hp}}/{{item.derived.hp}}</text>
              </view>
              <view class="stat-item">
                <text class="stat-lbl">SAN</text>
                <text class="stat-val">{{item.combat.sanCurrent || item.derived.sanStart}}/{{item.derived.sanStart}}</text>
              </view>
              <view class="stat-item">
                <text class="stat-lbl">MP</text>
                <text class="stat-val">{{item.combat.mpCurrent || item.derived.mp}}/{{item.derived.mp}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 删除按钮（藏在右侧，滑动后露出） -->
        <view class="swipe-delete-btn" catchtap="onDeleteTap" data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </view>

      <!-- 提示文字（仅列表有内容时显示） -->
      <view wx:if="{{index === characters.length - 1}}" class="list-footer-tip">
        <text>右滑可删除角色 · 最多支持创建5个角色卡</text>
      </view>
    </view>
  </block>

  <!-- 吸底按钮栏：新建调查员(3/4) + 我的(1/4) -->
  <view class="bottom-bar" wx:if="{{!diceMode}}">
    <view class="bottom-bar-create" bindtap="onCreateTap">
      <text class="bottom-bar-icon">+</text>
      <text>新建调查员</text>
    </view>
    <view class="bottom-bar-mine" bindtap="onMineTap">
      <text>我的</text>
    </view>
  </view>

  <!-- 我的弹窗 -->
  <view class="mine-modal-mask" wx:if="{{showMineModal}}" bindtap="onMineModalClose">
    <view class="mine-modal" catchtap="">
      <view class="mine-modal-title">账号管理</view>
      <view class="mine-modal-info">
        <text class="mine-modal-label">当前账号</text>
        <text class="mine-modal-value">{{userInfo.nickName || '未知用户'}}</text>
      </view>
      <view class="mine-modal-btn logout" bindtap="onLogoutTap">退出登录</view>
      <view class="mine-modal-btn close" bindtap="onMineModalClose">关闭</view>
    </view>
  </view>

</view>
