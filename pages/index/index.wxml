<view class="page-container" catchtap="onPageTap">

  <!-- ===== 背景图 ===== -->
  <image class="page-bg" src="{{bgImage}}" mode="aspectFill"/>

  <!-- ===== 自定义导航栏 ===== -->
  <view class="custom-nav" style="height:{{navBarHeight}}px;">
    <view class="custom-nav-title" style="top:{{statusBarHeight}}px;height:{{navHeight}}px;">
      <text>调查员名册</text>
    </view>
  </view>

  <!-- ===== 主体滚动区 ===== -->
  <scroll-view scroll-y class="main-scroll" style="height:{{scrollViewHeight}}px" enhanced="{{true}}" bounces="{{false}}">

    <!-- 导航栏占位 -->
    <view style="height:{{navBarHeight}}px;"></view>

    <!-- 空状态 -->
    <view wx:if="{{characters.length === 0}}" class="empty-state">
      <view class="empty-icon">📜</view>
      <text class="empty-title">尚无调查员</text>
      <text class="empty-desc">点击底部"＋"按钮创建第一个角色卡</text>
    </view>

    <!-- 角色卡列表 -->
    <view wx:else class="character-list">

      <view
        class="character-card"
        wx:for="{{characters}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onCardTap"
        bindlongpress="onCardLongPress"
      >
        <!-- 背景图：mingce.png 撑开卡片高度 -->
        <image
          class="card-bg"
          src="{{cardBgImage}}"
          mode="widthFix"
        />

        <!-- 信息区：绝对定位覆盖在背景图上方 -->
        <view class="card-top">
          <view class="card-header">
            <text class="card-name">{{item.name || '未命名调查员'}}</text>
            <text class="card-date" wx:if="{{item.createdAt}}">{{item.createdAt}}</text>
          </view>
          <view class="card-meta">
            <text wx:if="{{item.age}}">{{item.age}}岁</text>
            <text wx:if="{{item.age && item.gender}}"> · </text>
            <text wx:if="{{item.gender}}">{{item.gender}}</text>
            <text wx:if="{{(item.age || item.gender) && item.occupation}}"> · </text>
            <text wx:if="{{item.occupation}}">{{item.occupation}}</text>
          </view>
        </view>

        <!-- 属性区：绝对定位覆盖在背景图底部 -->
        <view class="card-stats">
          <view class="card-stat">
            <text class="card-stat-lbl">HP</text>
            <text class="card-stat-current">{{item.combat.hpCurrent || item.derived.hp}}</text>
            <text class="card-stat-sep">/</text>
            <text class="card-stat-max">{{item.derived.hp}}</text>
          </view>
          <view class="card-stat">
            <text class="card-stat-lbl">SAN</text>
            <text class="card-stat-current">{{item.combat.sanCurrent || item.derived.sanStart}}</text>
            <text class="card-stat-sep">/</text>
            <text class="card-stat-max">{{item.derived.sanStart}}</text>
          </view>
          <view class="card-stat">
            <text class="card-stat-lbl">MP</text>
            <text class="card-stat-current">{{item.combat.mpCurrent || item.derived.mp}}</text>
            <text class="card-stat-sep">/</text>
            <text class="card-stat-max">{{item.derived.mp}}</text>
          </view>
        </view>

      </view><!-- end character-card -->

    </view><!-- end character-list -->

  </scroll-view>

  <!-- ===== 骰子工具组件 ===== -->
  <dice-tool
    id="diceTool"
    fab-bottom-default="200"
    fab-bg="#f5f5f0"
    throw-btn-bg="linear-gradient(135deg, #e8b830, #c89a20)"
    bottom-limit="150"
    bind:close="onDiceClose"
  />

  <!-- ===== 正常底部按钮栏 ===== -->
  <view class="bottom-bar" wx:if="{{!deleteMode}}">
    <view class="bottom-bar-row">
      <view class="bottom-bar-create {{isLoggedIn ? '' : 'bottom-bar-create-disabled'}}" bindtap="onCreateTap">
        <text class="bottom-bar-icon" wx:if="{{isLoggedIn}}">+</text>
        <text>{{isLoggedIn ? '新建调查员' : '登录后可新建人物'}}</text>
      </view>
      <view class="bottom-bar-mine" bindtap="onMineTap">
        <text>我的</text>
      </view>
    </view>
    <view class="bottom-bar-tip" wx:if="{{characters.length > 0}}">
      <text>长按卡片可删除角色 · 最多支持创建5个角色卡</text>
    </view>
  </view>

  <!-- ===== 删除模式：红色删除栏 ===== -->
  <view class="bottom-bar-delete" wx:if="{{deleteMode}}">
    <view class="bottom-bar-delete-btn" bindtap="onDeleteConfirm">
      <text>删除「{{deleteTargetName}}」</text>
    </view>
    <view class="delete-cancel-btn" bindtap="onDeleteCancel">
      <text>取消</text>
    </view>
  </view>

  <!-- ===== 我的弹窗 ===== -->
  <view class="mine-modal-mask" wx:if="{{showMineModal}}" bindtap="onMineModalClose">
    <view class="mine-modal" catchtap="">
      <view class="mine-modal-title">账号管理</view>
      <view class="mine-modal-info">
        <text class="mine-modal-label">当前账号</text>
        <text class="mine-modal-value">{{userInfo.nickName || '未知用户'}}</text>
      </view>
      <view class="mine-modal-btn logout" bindtap="onLogoutTap">退出登录</view>
      <view class="mine-modal-btn close" bindtap="onMineModalClose">关闭</view>
    </view>
  </view>

</view>
