/* components/dice-tool/dice-tool.wxss */

/* ============================================================
   骰子浮动按钮
   ============================================================ */
.dice-fab {
  position: fixed;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  z-index: 20;
}

/* ============================================================
   骰子叠加层
   ============================================================ */
.dice-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
}
.dice-overlay.visible {
  display: block;
}

.dice-canvas {
  width: 100%;
  height: 100%;
}

/* 骰子底部控制栏 - Grid 4列 + 投掷按钮跨两行 */
.dice-controls {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 130;
  display: grid;
  grid-template-columns: repeat(4, 1fr) auto;
  grid-template-rows: repeat(2, auto);
  gap: 8px;
  padding: 6px 12px 20px;
  align-items: center;
  background-color: #252533;
}

.dice-btn-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dice-btn {
  background-color: rgba(60, 60, 80, 0.9);
  color: #ffffff;
  font-size: 14px;
  font-weight: bold;
  padding: 2px 8px;
  border-radius: 6px;
  border: 1px solid rgba(100, 100, 130, 0.5);
  min-width: 40px;
  text-align: center;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
  width: 100%;
  height: 40px;
  line-height: 36px;
}

.dice-btn:active {
  background-color: rgba(80, 80, 110, 0.9);
  transform: scale(0.95);
}

/* 骰子数量 tag */
.dice-count {
  position: absolute;
  top: -6px;
  right: -6px;
  background-color: #ff4444;
  color: #ffffff;
  font-size: 11px;
  font-weight: bold;
  min-width: 16px;
  height: 16px;
  line-height: 16px;
  text-align: center;
  border-radius: 8px;
  padding: 0 4px;
}

/* 右侧投掷区域 */
.throw-area {
  grid-column: 5;
  grid-row: 1 / 3;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 4px;
}
.throw-collapse {
  color: rgba(255, 255, 255, 0.45);
  font-size: 20rpx;
  text-align: center;
  padding: 4rpx 0;
}

/* 投掷按钮（背景色通过 WXML inline style 注入） */
.throw-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 18px;
  font-weight: bold;
  padding: 0 20px;
  border-radius: 12px;
  height: 66px;
}
.throw-btn:active {
  transform: scale(0.95);
}
.throw-btn.disabled {
  opacity: 0.4;
}

/* 结果卡片（×1.25 等比放大） */
.dice-result-panel {
  position: fixed;
  top: 200rpx;
  left: 50%;
  margin-left: -338rpx;
  width: 675rpx;
  height: 529rpx;
  z-index: 140;
  border-radius: 25rpx;
  overflow: hidden;
}
.drp-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
.drp-body {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  height: 100%;
  padding: 40rpx;
  box-sizing: border-box;
}
.drp-left {
  width: 375rpx;
  flex-shrink: 0;
  display: flex;
  flex-wrap: wrap;
  align-content: flex-start;
}
.drp-item {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  width: 125rpx;
  flex-shrink: 0;
  margin-bottom: 8rpx;
}
.drpi-type {
  color: #FFFFFF;
  font-size: 45rpx;
  margin-right: 5rpx;
  line-height: 1.3;
}
.drpi-val {
  color: #AA3442;
  font-size: 60rpx;
  font-weight: bold;
  line-height: 1.3;
}
.drp-divider {
  width: 3rpx;
  margin: 0 20rpx;
  background: rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}
.drp-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
}
.drpr-label {
  color: #FFFFFF;
  font-size: 45rpx;
}
.drpr-num {
  color: #AA3442;
  font-size: 85rpx;
  font-weight: bold;
}
